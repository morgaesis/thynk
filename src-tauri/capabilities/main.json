{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "main-capability",
  "description": "Main window capability for Thynk desktop app",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-open",
    "dialog:allow-open",
    "dialog:allow-save",
    "dialog:allow-message",
    "dialog:allow-ask",
    "fs:allow-read",
    "fs:allow-write",
    "fs:allow-exists",
    "fs:allow-mkdir",
    "fs:allow-remove",
    "fs:allow-rename",
    "fs:allow-copy-file",
    "fs:allow-read-dir",
    "fs:allow-read-file",
    "fs:allow-read-text-file",
    "fs:allow-write-file",
    "fs:allow-write-text-file",
    "fs:scope-appdata-recursive",
    "fs:scope-home-recursive",
    "fs:scope-data-recursive",
    "fs:scope-resource-recursive",
    "fs:scope-download-recursive",
    "fs:scope-desktop-recursive",
    "fs:scope-document-recursive",
    "fs:scope-picture-recursive",
    "fs:scope-video-recursive",
    "fs:scope-audio-recursive",
    {
      "identifier": "fs:scope",
      "allow": [{ "path": "**" }]
    },
    "process:allow-exit",
    "process:allow-restart",
    "opener:allow-open-url",
    "opener:allow-open-path"
  ]
}
