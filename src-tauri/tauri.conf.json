{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Thynk",
  "version": "0.1.0",
  "identifier": "com.thynk.app",
  "build": {
    "beforeDevCommand": "cd ../frontend && bun run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "cd ../frontend && bun run build",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Thynk",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    }
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "fs": {
      "scope": ["$APPDATA/**", "$HOME/**", "$DATA/**", "**"]
    }
  }
}
